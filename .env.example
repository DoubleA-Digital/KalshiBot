# Kalshi credentials
KALSHI_KEY_ID=your-key-id-here
KALSHI_PRIVATE_KEY_PATH=./kalshi_private_key.pem

# Environment: "demo" or "prod"
KALSHI_ENV=demo

# SAFETY: real money trading is OFF unless this is exactly "true"
LIVE_TRADING=false

# Rate limiting (requests per second, conservative default)
KALSHI_RPS=8
